NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-jwt
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-jwt

# Para el análisis de comida por foto (visión de Gemini — key gratis en aistudio.google.com/app/apikey)
GEMINI_API_KEY=...

# Notificaciones push / recordatorios (opcional).
# Generá el par de claves con:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-email@ejemplo.com
# Secreto que protege el endpoint /api/notifications/cron-send (poné cualquier string largo)
CRON_SECRET=
